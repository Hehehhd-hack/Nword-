-- ═══════════════════════════════════════════
local function setStatus(txt, col)
    statusTxt.Text = txt
    local c = col or C.green
    tw(statusTxt,{TextColor3=c},.15)
    tw(statusDot, {BackgroundColor3=c},.15)
end

local function setProgress(pct)
    tw(progFill,{Size=UDim2.new(math.clamp(pct,0,1),0,1,0)},.1)
end

local function updateInfo()
    local n = #MS.inputs
    local dur = n>0 and MS.inputs[n].time or 0
    vInputs.Text   = tostring(n)
    vDuration.Text = string.format("%.2fs",dur)
end

function MS:StartRec()
    if self.playing then return end
    self.recording=true; self.inputs={}; self.recStart=tick()
    setStatus("Recording…",C.red)
    recBtn:RC(Color3.fromRGB(140,30,30)); recBtn.Text="⏹  Stop"
    updateInfo()
end

function MS:StopRec()
    if not self.recording then return end
    self.recording=false
    updateInfo()
    setStatus("Recorded "..#self.inputs.." inputs",C.yellow)
    recBtn:RC(C.red); recBtn.Text="⏺  Record"
    setProgress(0)
end

function MS:StopPlay()
    self.stopReq=true; self.playing=false
    setStatus("Stopped",C.muted)
    playBtn:RC(C.green); playBtn.Text="▶  Play"
    loopLbl.Text=""; setProgress(0)
end

function MS:PlayOnce(inputs, totalDur)
    local base=tick()
    for _,ev in ipairs(inputs) do
        if self.stopReq then return false end
        local target=base+(ev.time/CFG.speedMult)
        local now=tick()
        if target>now then task.wait(target-now) end
        if self.stopReq then return false end
        if VIM then
            pcall(function()
                if ev.t=="TD" or ev.t=="MD" then
                    VIM:SendMouseButtonEvent(ev.x,ev.y,0,true,game,0)
                elseif ev.t=="TU" or ev.t=="MU" then
                    VIM:SendMouseButtonEvent(ev.x,ev.y,0,false,game,0)
                elseif ev.t=="TM" or ev.t=="MM" then
                    VIM:SendMouseMoveEvent(ev.x,ev.y,game)
                end
            end)
        end
        if totalDur>0 then setProgress(ev.time/totalDur) end
    end
    return true
end

function MS:Play()
    if self.recording then self:StopRec() end
    if self.playing then self:StopPlay(); return end
    if #self.inputs==0 then setStatus("Nothing to play!",C.red); return end
    self.playing=true; self.stopReq=false
    playBtn:RC(C.yellow); playBtn.Text="⏸  Stop"
    local inputs=self.inputs
    local totalDur=inputs[#inputs] and inputs[#inputs].time or 0
    task.spawn(function()
        if CFG.startDelay>0 then
            setStatus(string.format("Starting in %.1fs…",CFG.startDelay),C.yellow)
            task.wait(CFG.startDelay)
            if self.stopReq then self:StopPlay(); return end
        end
        local maxL=CFG.loopCount==0 and math.huge or CFG.loopCount
        local loop=0
        while loop<maxL and not self.stopReq do
            loop=loop+1
            loopLbl.Text=CFG.loopCount==0 and string.format("Loop %d / ∞",loop) or string.format("Loop %d / %d",loop,CFG.loopCount)
            setStatus("Playing…",C.green)
            local ok=self:PlayOnce(inputs,totalDur)
            if not ok or self.stopReq then break end
            setProgress(1)
            if loop<maxL and CFG.loopDelay>0 and not self.stopReq then
                setStatus(string.format("Loop pause %.1fs…",CFG.loopDelay),C.yellow)
                task.wait(CFG.loopDelay)
            end
        end
        if not self.stopReq then
            self:StopPlay()
            setStatus(string.format("Done (%d loop%s)",loop,loop==1 and "" or "s"),C.green)
        end
    end)
end

function MS:RefreshList()
    for _,c in ipairs(macScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    local idx=0
    for name,data in pairs(self.macros) do
        idx=idx+1
        local row=Instance.new("Frame")
        row.Parent=macScroll; row.BackgroundColor3=C.card
        row.BorderSizePixel=0; row.Size=UDim2.new(1,0,0,38)
        row.LayoutOrder=idx; rnd(row,7)

        local rl=Instance.new("UIListLayout"); rl.Parent=row
        rl.FillDirection=Enum.FillDirection.Horizontal
        rl.VerticalAlignment=Enum.VerticalAlignment.Center
        local rp=Instance.new("UIPadding"); rp.Parent=row
        rp.PaddingLeft=UDim.new(0,10); rp.PaddingRight=UDim.new(0,6)

        local nL=Instance.new("TextLabel"); nL.Parent=row
        nL.BackgroundTransparency=1; nL.Size=UDim2.new(1,-80,1,0)
        nL.Text=name; nL.TextSize=12; nL.Font=Enum.Font.GothamBold
        nL.TextColor3=C.text; nL.TextXAlignment=Enum.TextXAlignment.Left

        local cL=Instance.new("TextLabel"); cL.Parent=row
        cL.BackgroundTransparency=1; cL.Size=UDim2.new(0,46,1,0)
        cL.Text=#data.inputs.." ev"; cL.TextSize=11
        cL.Font=Enum.Font.Gotham; cL.TextColor3=C.sub
        cL.TextXAlignment=Enum.TextXAlignment.Right

        local delB=btn(row,"✕",0,0,26,26,Color3.fromRGB(60,20,20),C.red)
        delB.Size=UDim2.new(0,26,0,26)

        row.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
                nameBox.Text=name; MS.inputs=data.inputs; updateInfo()
                setStatus("Loaded: "..name,C.purple); switchTab(1)
            end
        end)
        delB.MouseButton1Click:Connect(function()
            self.macros[name]=nil; self:RefreshList()
        end)
    end
    if idx==0 then
        local e=Instance.new("TextLabel"); e.Parent=macScroll
        e.BackgroundTransparency=1; e.Size=UDim2.new(1,0,0,36)
        e.Text="No saved macros"; e.TextSize=12
        e.Font=Enum.Font.Gotham; e.TextColor3=C.muted
        e.TextXAlignment=Enum.TextXAlignment.Center
    end
end

