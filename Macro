local function mkCorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = p
end

local function mkPad(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft   = UDim.new(0, l or 0)
    u.PaddingRight  = UDim.new(0, r or 0)
    u.Parent = p
end

local function mkLabel(p, txt, sz, col, font, xa)
    local l = Instance.new("TextLabel")
    l.Parent             = p
    l.BackgroundTransparency = 1
    l.Text               = txt
    l.TextSize           = sz  or 13
    l.TextColor3         = col or C.text
    l.Font               = font or Enum.Font.Gotham
    l.TextXAlignment     = xa  or Enum.TextXAlignment.Left
    l.Size               = UDim2.new(1, 0, 0, (sz or 13) + 4)
    l.TextTruncate       = Enum.TextTruncate.AtEnd
    return l
end

-- Button with press feel
local function mkBtn(p, txt, bg, fg, order)
    local b = Instance.new("TextButton")
    b.Parent           = p
    b.BackgroundColor3 = bg
    b.BorderSizePixel  = 0
    b.Font             = Enum.Font.GothamBold
    b.Text             = txt
    b.TextColor3       = fg or C.text
    b.TextSize         = 13
    b.AutoButtonColor  = false
    b.LayoutOrder      = order or 0
    b.ClipsDescendants = true
    mkCorner(b, 8)

    local orig = bg
    b.MouseButton1Down:Connect(function()
        tw(b, {BackgroundColor3 = orig:Lerp(Color3.new(1,1,1), 0.2)}, 0.06)
    end)
    b.MouseButton1Up:Connect(function()
        tw(b, {BackgroundColor3 = orig}, 0.12)
    end)

    -- allow re-colouring
    function b:Recolor(newBg)
        orig = newBg
        b.BackgroundColor3 = newBg
    end

    return b
end

