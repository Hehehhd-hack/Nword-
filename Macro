--  ROW BUILDER  (places elements at Y, advances Y)
-- ════════════════════════════════════════
local Y = 0   -- current Y cursor inside canvas

local function advance(h)
    Y = Y + h
end

local function place(h, bg)
    local f = Instance.new("Frame")
    f.Parent          = scroll
    f.BackgroundColor3 = bg or BG
    f.BorderSizePixel = 0
    f.Position        = UDim2.new(0, 0, 0, Y)
    f.Size            = UDim2.new(1, 0, 0, h)
    advance(h)
    return f
end

