-- ═══════════════════════════════════════════
--  HELPERS
-- ═══════════════════════════════════════════
local function tw(o, p, t, s, d)
    TS:Create(o, TweenInfo.new(t or .18, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out), p):Play()
end

local function rnd(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p
end

local function stroke(p, col, thick)
    local s = Instance.new("UIStroke"); s.Color = col or C.card; s.Thickness = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = p
end

local function frame(p, bg, x, y, w, h, r)
    local f = Instance.new("Frame")
    f.Parent = p; f.BackgroundColor3 = bg or C.panel; f.BorderSizePixel = 0
    f.Position = UDim2.new(0,x,0,y); f.Size = UDim2.new(0,w,0,h)
    if r then rnd(f, r) end
    return f
end

local function lbl(p, txt, x, y, w, h, sz, col, font, xa)
    local l = Instance.new("TextLabel")
    l.Parent = p; l.BackgroundTransparency = 1
    l.Position = UDim2.new(0,x,0,y); l.Size = UDim2.new(0,w,0,h)
    l.Text = txt; l.TextSize = sz or 13; l.TextColor3 = col or C.text
    l.Font = font or Enum.Font.Gotham
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.TextTruncate = Enum.TextTruncate.AtEnd
    return l
end

local function btn(p, txt, x, y, w, h, bg, fg, r)
    local b = Instance.new("TextButton")
    b.Parent = p; b.BackgroundColor3 = bg or C.card; b.BorderSizePixel = 0
    b.Position = UDim2.new(0,x,0,y); b.Size = UDim2.new(0,w,0,h)
    b.Text = txt; b.TextSize = 13; b.Font = Enum.Font.GothamBold
    b.TextColor3 = fg or C.text; b.AutoButtonColor = false
    rnd(b, r or 8)
    local orig = bg or C.card
    b.MouseButton1Down:Connect(function() tw(b,{BackgroundColor3=orig:Lerp(C.white,.2)},.06) end)
    b.MouseButton1Up:Connect(function()   tw(b,{BackgroundColor3=orig},.12) end)
    function b:RC(c) orig=c; b.BackgroundColor3=c end
    return b
end

