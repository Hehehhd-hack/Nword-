-- ── Drag ────────────────────────────────
do
    local drag, dInp, dStart, dPos = false, nil, nil, nil
    titleBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; dInp = i; dStart = i.Position; dPos = win.Position
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not drag then return end
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseMovement then
            local d  = i.Position - dStart
            local vp = workspace.CurrentCamera.ViewportSize
            win.Position = UDim2.new(0,
                math.clamp(dPos.X.Offset + d.X, 0, vp.X - WIN_W), 0,
                math.clamp(dPos.Y.Offset + d.Y, 0, vp.Y - WIN_H))
        end
    end)
    UIS.InputEnded:Connect(function(i) if i == dInp then drag = false end end)
end

