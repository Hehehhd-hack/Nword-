-- ════════════════════════════════════════
--  DRAG  — transparent TextButton overlay
--  This is the key fix: a TextButton on top
--  of the title bar captures touch correctly
-- ════════════════════════════════════════
local dragHandle = Instance.new("TextButton")
dragHandle.Parent             = titleBar
dragHandle.BackgroundTransparency = 1
dragHandle.BorderSizePixel    = 0
dragHandle.Position           = UDim2.new(0, 0, 0, 0)
dragHandle.Size               = UDim2.new(1, -64, 1, 0)  -- leave room for buttons
dragHandle.Text               = ""
dragHandle.AutoButtonColor    = false
dragHandle.ZIndex             = 7  -- above everything in title bar

do
    local dragging = false
    local dragStart = Vector2.new()
    local winStart  = Vector2.new()

    dragHandle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = Vector2.new(inp.Position.X, inp.Position.Y)
            winStart  = Vector2.new(win.Position.X.Offset, win.Position.Y.Offset)
        end
    end)

    dragHandle.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseMovement then
            local dx = inp.Position.X - dragStart.X
            local dy = inp.Position.Y - dragStart.Y
            local vp = workspace.CurrentCamera.ViewportSize
            local nx = math.clamp(winStart.X + dx, 0, vp.X - WIN_W)
            local ny = math.clamp(winStart.Y + dy, 0, vp.Y - WIN_H)
            win.Position = UDim2.new(0, nx, 0, ny)
        end
    end)

    dragHandle.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

