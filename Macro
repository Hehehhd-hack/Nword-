-- Slider factory
local function mkSlider(parent, title, minV, maxV, defV, step, fmt, onChange, order)
    local sec = mkSection(parent, title, order)

    local valLbl = mkLabel(sec, fmt(defV), 16, C.aHi, Enum.Font.GothamBold, Enum.TextXAlignment.Right)
    valLbl.Size        = UDim2.new(1, 0, 0, 20)
    valLbl.LayoutOrder = 1

    local track = Instance.new("Frame")
    track.Parent           = sec
    track.BackgroundColor3 = C.card
    track.BorderSizePixel  = 0
    track.Size             = UDim2.new(1, 0, 0, 6)
    track.LayoutOrder      = 2
    mkCorner(track, 99)

    local fill = Instance.new("Frame")
    fill.Parent           = track
    fill.BackgroundColor3 = C.accent
    fill.BorderSizePixel  = 0
    fill.Size             = UDim2.new((defV-minV)/(maxV-minV), 0, 1, 0)
    mkCorner(fill, 99)

    local knob = Instance.new("TextButton")
    knob.Parent           = track
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel  = 0
    knob.Text             = ""
    knob.AutoButtonColor  = false
    knob.Size             = UDim2.new(0, 18, 0, 18)
    knob.Position         = UDim2.new((defV-minV)/(maxV-minV), -9, 0.5, -9)
    mkCorner(knob, 99)

    local cur     = defV
    local isDrag  = false

    local function applyPct(pct)
        pct = math.clamp(pct, 0, 1)
        local raw = minV + pct*(maxV-minV)
        cur = math.round(raw/step)*step
        cur = math.clamp(cur, minV, maxV)
        local p = (cur-minV)/(maxV-minV)
        fill.Size     = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, -9, 0.5, -9)
        valLbl.Text   = fmt(cur)
        onChange(cur)
    end

    local function pctFromInput(pos)
        local abs = track.AbsolutePosition
        local sz  = track.AbsoluteSize
        return (pos.X - abs.X) / sz.X
    end

    knob.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            isDrag = true
        end
    end)
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            isDrag = true
            applyPct(pctFromInput(inp.Position))
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if not isDrag then return end
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseMovement then
            applyPct(pctFromInput(inp.Position))
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            isDrag = false
        end
    end)
end

