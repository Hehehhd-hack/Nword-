local function sliderRow(title, minV, maxV, defV, step, fmt, onChange)
    local f = place(RH.slider, PANEL)

    local tl = Instance.new("TextLabel")
    tl.Parent=f; tl.BackgroundTransparency=1
    tl.Position=UDim2.new(0,12,0,6); tl.Size=UDim2.new(0.55,0,0,18)
    tl.Text=title; tl.TextSize=10; tl.Font=Enum.Font.GothamBold
    tl.TextColor3=SUB; tl.TextXAlignment=Enum.TextXAlignment.Left
    tl.TextYAlignment=Enum.TextYAlignment.Center

    local vl = Instance.new("TextLabel")
    vl.Parent=f; vl.BackgroundTransparency=1
    vl.Position=UDim2.new(0.45,0,0,6); vl.Size=UDim2.new(0.55,-12,0,18)
    vl.Text=fmt(defV); vl.TextSize=15; vl.Font=Enum.Font.GothamBold
    vl.TextColor3=ACC; vl.TextXAlignment=Enum.TextXAlignment.Right
    vl.TextYAlignment=Enum.TextYAlignment.Center

    local track = Instance.new("Frame")
    track.Parent=f; track.BackgroundColor3=CARD; track.BorderSizePixel=0
    track.Position=UDim2.new(0,12,0,36); track.Size=UDim2.new(1,-24,0,6)
    do local c=Instance.new("UICorner");c.CornerRadius=UDim.new(1,0);c.Parent=track end

    local fill = Instance.new("Frame")
    fill.Parent=track; fill.BackgroundColor3=ACC; fill.BorderSizePixel=0
    fill.Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0)
    do local c=Instance.new("UICorner");c.CornerRadius=UDim.new(1,0);c.Parent=fill end

    local knob = Instance.new("TextButton")
    knob.Parent=track; knob.BackgroundColor3=WHITE; knob.BorderSizePixel=0
    knob.Text=""; knob.AutoButtonColor=false
    knob.Size=UDim2.new(0,22,0,22)
    knob.Position=UDim2.new((defV-minV)/(maxV-minV),-11,0.5,-11)
    do local c=Instance.new("UICorner");c.CornerRadius=UDim.new(1,0);c.Parent=knob end

    local isDrag = false
    local cur    = defV

    local function apply(pct)
        pct = math.clamp(pct, 0, 1)
        cur = math.clamp(math.round((minV + pct*(maxV-minV)) / step) * step, minV, maxV)
        local p = (cur-minV)/(maxV-minV)
        fill.Size     = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, -11, 0.5, -11)
        vl.Text       = fmt(cur)
        onChange(cur)
    end
    local function pctOf(pos)
        local ap = track.AbsolutePosition
        local as = track.AbsoluteSize
        if as.X == 0 then return 0 end
        return (pos.X - ap.X) / as.X
    end

    knob.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
            isDrag=true
        end
    end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
            isDrag=true; apply(pctOf(i.Position))
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not isDrag then return end
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement then
            apply(pctOf(i.Position))
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
            isDrag=false
        end
    end)
end

