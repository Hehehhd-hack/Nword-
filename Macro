function MS:SetStatus(txt, col)
    _G._DMstxt.Text      = txt
    local c = col or C.green
    tw(_G._DMstxt, {TextColor3 = c}, 0.15)
    tw(_G._DMdot,  {BackgroundColor3 = c}, 0.15)
end

function MS:SetProgress(pct)
    tw(_G._DMfill, {Size = UDim2.new(math.clamp(pct,0,1), 0, 1, 0)}, 0.1)
end

function MS:UpdateInfo()
    local n   = #self.inputs
    local dur = n > 0 and self.inputs[n].time or 0
    infoValues["Inputs"].Text   = tostring(n)
    infoValues["Duration"].Text = string.format("%.2fs", dur)
end

function MS:StartRec()
    if self.playing then return end
    self.recording    = true
    self.inputs       = {}
    self.recStartTime = tick()
    self:SetStatus("Recording…", C.red)
    _G._DMrecBtn:Recolor(Color3.fromRGB(140,30,30))
    _G._DMrecBtn.Text = "⏹  Stop Rec"
    self:UpdateInfo()
end

function MS:StopRec()
    if not self.recording then return end
    self.recording = false
    self:UpdateInfo()
    self:SetStatus("Recorded "..#self.inputs.." inputs", C.yellow)
    _G._DMrecBtn:Recolor(C.red)
    _G._DMrecBtn.Text = "⏺  Record"
    self:SetProgress(0)
end

function MS:StopPlay()
    self.stopReq  = true
    self.playing  = false
    self:SetStatus("Stopped", C.muted)
    _G._DMplayBtn.Text = "▶  Play"
    _G._DMplayBtn:Recolor(C.green)
    _G._DMloopLbl.Text = ""
    self:SetProgress(0)
end

-- Core playback: replay one pass through recorded inputs
function MS:PlayOnce(inputs, totalDur)
    local base = tick()
    for _, ev in ipairs(inputs) do
        if self.stopReq then return false end

        -- Wait until this event's timestamp (adjusted for speed)
        local target = base + (ev.time / CFG.speedMult)
        local now    = tick()
        if target > now then
            task.wait(target - now)
        end

        if self.stopReq then return false end

        -- ── Replay event ──────────────────────
        if VIM then
            pcall(function()
                if ev.type == "TouchStart" or ev.type == "MouseDown" then
                    VIM:SendMouseButtonEvent(ev.pos.X, ev.pos.Y, 0, true,  game, 0)
                elseif ev.type == "TouchEnd" or ev.type == "MouseUp" then
                    VIM:SendMouseButtonEvent(ev.pos.X, ev.pos.Y, 0, false, game, 0)
                elseif ev.type == "TouchMoved" or ev.type == "MouseMoved" then
                    VIM:SendMouseMoveEvent(ev.pos.X, ev.pos.Y, game)
                end
            end)
        end

        -- Update progress bar
        if totalDur > 0 then
            self:SetProgress(ev.time / totalDur)
        end
    end
    return true
end

function MS:Play()
    if self.recording then self:StopRec() end
    if self.playing    then self:StopPlay(); return end
    if #self.inputs == 0 then
        self:SetStatus("Nothing to play!", C.red); return
    end

    self.playing  = true
    self.stopReq  = false
    _G._DMplayBtn.Text = "⏸  Stop"
    _G._DMplayBtn:Recolor(C.yellow)

    local inputs   = self.inputs
    local totalDur = inputs[#inputs] and inputs[#inputs].time or 0

    task.spawn(function()
        -- Start delay
        if CFG.startDelay > 0 then
            self:SetStatus(string.format("Starting in %.1fs…", CFG.startDelay), C.yellow)
            task.wait(CFG.startDelay)
            if self.stopReq then self:StopPlay(); return end
        end

        local maxLoops = CFG.loopCount == 0 and math.huge or CFG.loopCount
        local loop = 0

        while loop < maxLoops and not self.stopReq do
            loop = loop + 1

            _G._DMloopLbl.Text = CFG.loopCount == 0
                and string.format("Loop %d / ∞", loop)
                or  string.format("Loop %d / %d", loop, CFG.loopCount)

            self:SetStatus("Playing…", C.green)

            local ok = self:PlayOnce(inputs, totalDur)
            if not ok or self.stopReq then break end

            self:SetProgress(1)

            if loop < maxLoops and CFG.loopDelay > 0 and not self.stopReq then
                self:SetStatus(string.format("Loop pause %.1fs…", CFG.loopDelay), C.yellow)
                task.wait(CFG.loopDelay)
            end
        end

        if not self.stopReq then
            self:StopPlay()
            self:SetStatus(string.format("Done (%d loop%s)", loop, loop==1 and "" or "s"), C.green)
        end
    end)
end

function MS:RefreshMacroList()
    for _, c in ipairs(macListScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    local idx = 0
    for name, data in pairs(self.macros) do
        idx = idx + 1
        local row = Instance.new("Frame")
        row.Parent           = macListScroll
        row.BackgroundColor3 = C.card
        row.BorderSizePixel  = 0
        row.Size             = UDim2.new(1, 0, 0, 38)
        row.LayoutOrder      = idx
        mkCorner(row, 7)

        local rl = Instance.new("UIListLayout")
        rl.Parent            = row
        rl.FillDirection     = Enum.FillDirection.Horizontal
        rl.VerticalAlignment = Enum.VerticalAlignment.Center
        mkPad(row, 0, 0, 10, 6)

        local nLbl = mkLabel(row, name, 12, C.text, Enum.Font.GothamBold)
        nLbl.Size = UDim2.new(1, -80, 1, 0)

        local cntLbl = mkLabel(row, #data.inputs.." ev", 11, C.sub, Enum.Font.Gotham, Enum.TextXAlignment.Right)
        cntLbl.Size = UDim2.new(0, 46, 1, 0)

        local del = mkBtn(row, "✕", Color3.fromRGB(70,25,25), C.red)
        del.Size = UDim2.new(0, 26, 0, 26)

        -- tap row = load
        row.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch
            or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                nameBox.Text = name
                MS.inputs = data.inputs
                MS:UpdateInfo()
                MS:SetStatus("Loaded: "..name, Color3.fromRGB(160,100,255))
                switchTab(1)
            end
        end)

        del.MouseButton1Click:Connect(function()
            MS.macros[name] = nil
            MS:RefreshMacroList()
        end)
    end

    if idx == 0 then
        local e = mkLabel(macListScroll, "No saved macros", 12, C.muted, Enum.Font.Gotham, Enum.TextXAlignment.Center)
        e.Size = UDim2.new(1, 0, 0, 36)
    end
end

-- ═══════════════════════════════════════════
--  INPUT RECORDING HOOKS
-- ═══════════════════════════════════════════
local function rec(evType, pos)
    if not MS.recording then return end
    -- ignore inputs that land inside the UI window
    local absPos = win.AbsolutePosition
    local absSize = win.AbsoluteSize
    if pos.X >= absPos.X and pos.X <= absPos.X + absSize.X
    and pos.Y >= absPos.Y and pos.Y <= absPos.Y + absSize.Y then
        return
    end
    local t = tick() - MS.recStartTime
    table.insert(MS.inputs, {type = evType, pos = pos, time = t})
    MS:UpdateInfo()
end

-- Touch
UIS.TouchStarted:Connect(function(touch, _) rec("TouchStart",  touch.Position) end)
UIS.TouchMoved:Connect(  function(touch, _) rec("TouchMoved",  touch.Position) end)
UIS.TouchEnded:Connect(  function(touch, _) rec("TouchEnd",    touch.Position) end)

-- Mouse (PC)
UIS.InputBegan:Connect(function(inp, _)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 and CFG.recordMouse then
        rec("MouseDown", inp.Position)
    end
end)
UIS.InputChanged:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseMovement
    and CFG.recordMouse and MS.recording then
        rec("MouseMoved", inp.Position)
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 and CFG.recordMouse then
        rec("MouseUp", inp.Position)
    end
end)

