buildPage(tabPages[2], function(place, spacer, divider, hdr)
    spacer(8)

    local function sliderRow(title, minV, maxV, defV, step, fmt, onChange)
        local f = place(72, PANEL)

        local tl=Instance.new("TextLabel"); tl.Parent=f; tl.BackgroundTransparency=1
        tl.Position=UDim2.new(0,12,0,7); tl.Size=UDim2.new(0.6,0,0,18)
        tl.Text=title; tl.TextSize=10; tl.Font=Enum.Font.GothamBold
        tl.TextColor3=SUB; tl.TextXAlignment=Enum.TextXAlignment.Left
        tl.TextYAlignment=Enum.TextYAlignment.Center

        local vl=Instance.new("TextLabel"); vl.Parent=f; vl.BackgroundTransparency=1
        vl.Position=UDim2.new(0.4,0,0,7); vl.Size=UDim2.new(0.6,-12,0,18)
        vl.Text=fmt(defV); vl.TextSize=15; vl.Font=Enum.Font.GothamBold
        vl.TextColor3=ACC; vl.TextXAlignment=Enum.TextXAlignment.Right
        vl.TextYAlignment=Enum.TextYAlignment.Center

        local track=Instance.new("Frame"); track.Parent=f
        track.BackgroundColor3=CARD; track.BorderSizePixel=0
        track.Position=UDim2.new(0,12,0,38); track.Size=UDim2.new(1,-24,0,6)
        rnd(track, 99)

        local fill=Instance.new("Frame"); fill.Parent=track
        fill.BackgroundColor3=ACC; fill.BorderSizePixel=0
        fill.Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0)
        rnd(fill, 99)

        local knob=Instance.new("TextButton"); knob.Parent=track
        knob.BackgroundColor3=WHITE; knob.BorderSizePixel=0
        knob.Text=""; knob.AutoButtonColor=false
        knob.Size=UDim2.new(0,22,0,22)
        knob.Position=UDim2.new((defV-minV)/(maxV-minV),-11,0.5,-11)
        rnd(knob, 99)

        local isDrag=false
        local cur=defV

        local function apply(pct)
            pct=math.clamp(pct,0,1)
            cur=math.clamp(math.round((minV+pct*(maxV-minV))/step)*step,minV,maxV)
            local p=(cur-minV)/(maxV-minV)
            fill.Size=UDim2.new(p,0,1,0)
            knob.Position=UDim2.new(p,-11,0.5,-11)
            vl.Text=fmt(cur)
            onChange(cur)
        end
        local function pOf(pos)
            local ap=track.AbsolutePosition; local as=track.AbsoluteSize
            if as.X==0 then return 0 end
            return (pos.X-ap.X)/as.X
        end

        knob.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=true end
        end)
        track.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
                isDrag=true; apply(pOf(i.Position))
            end
        end)
        UIS.InputChanged:Connect(function(i)
            if not isDrag then return end
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement then apply(pOf(i.Position)) end
        end)
        UIS.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=false end
        end)
    end

    hdr("LOOP COUNT  (0 = infinite)")
    sliderRow("LOOP COUNT", 0, 50, 1, 1,
        function(v) return v==0 and "∞" or tostring(math.floor(v)) end,
        function(v) CFG.loopCount=math.floor(v); if vLoops then vLoops.Text=v==0 and "∞" or tostring(math.floor(v)) end end)
    divider()

    hdr("PLAYBACK SPEED")
    sliderRow("SPEED", 0.25, 4.0, 1.0, 0.25,
        function(v) return string.format("%.2f×",v) end,
        function(v) CFG.speedMult=v; if vSpeed then vSpeed.Text=string.format("%.2f×",v) end end)
    divider()

    hdr("START DELAY (seconds)")
    sliderRow("START DELAY", 0, 10, 0, 0.5,
        function(v) return string.format("%.1fs",v) end,
        function(v) CFG.startDelay=v end)
    divider()

    hdr("LOOP DELAY (seconds)")
    sliderRow("LOOP DELAY", 0, 10, 0, 0.5,
        function(v) return string.format("%.1fs",v) end,
        function(v) CFG.loopDelay=v end)
    divider(); spacer(4)

    -- Toggle
    hdr("OPTIONS")
    local tRow = place(44, PANEL)
    do
        local tl=Instance.new("TextLabel"); tl.Parent=tRow; tl.BackgroundTransparency=1
        tl.Position=UDim2.new(0,12,0,0); tl.Size=UDim2.new(1,-66,1,0)
        tl.Text="Record PC mouse clicks"; tl.TextSize=13; tl.TextColor3=TEXT
        tl.Font=Enum.Font.Gotham; tl.TextXAlignment=Enum.TextXAlignment.Left
        tl.TextYAlignment=Enum.TextYAlignment.Center

        local state=CFG.recMouse
        local tog=Instance.new("TextButton"); tog.Parent=tRow
        tog.Size=UDim2.new(0,46,0,26); tog.Position=UDim2.new(1,-58,0.5,-13)
        tog.BackgroundColor3=state and ACC or CARD; tog.BorderSizePixel=0
        tog.Text=""; tog.AutoButtonColor=false; rnd(tog,99)
        local kn=Instance.new("Frame"); kn.Parent=tog; kn.BackgroundColor3=WHITE
        kn.BorderSizePixel=0; kn.Size=UDim2.new(0,20,0,20)
        kn.Position=state and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)
        rnd(kn,99)
        tog.MouseButton1Click:Connect(function()
            state=not state; CFG.recMouse=state
            tw(tog,{BackgroundColor3=state and ACC or CARD},.15)
            tw(kn,{Position=state and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)},.15)
        end)
    end
    spacer(8)
end)

