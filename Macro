-- Slider factory for settings page
local sliderIdx = 0
local function mkSlider(title, minV, maxV, defV, step, fmt, onChange)
    sliderIdx = sliderIdx + 1

    local card = Instance.new("Frame")
    card.Parent = spScroll
    card.BackgroundColor3 = C.panel
    card.BorderSizePixel = 0
    card.Size = UDim2.new(1, 0, 0, 72)
    card.LayoutOrder = sliderIdx
    rnd(card, 10)
    mkPad2(card)

    local tLbl = Instance.new("TextLabel")
    tLbl.Parent = card; tLbl.BackgroundTransparency = 1
    tLbl.Position = UDim2.new(0,0,0,0); tLbl.Size = UDim2.new(0.6,0,0,18)
    tLbl.Text = title; tLbl.TextSize = 10; tLbl.Font = Enum.Font.GothamBold
    tLbl.TextColor3 = C.sub; tLbl.TextXAlignment = Enum.TextXAlignment.Left
    tLbl.TextYAlignment = Enum.TextYAlignment.Center

    local vLbl = Instance.new("TextLabel")
    vLbl.Parent = card; vLbl.BackgroundTransparency = 1
    vLbl.Position = UDim2.new(0.5,0,0,0); vLbl.Size = UDim2.new(0.5,0,0,18)
    vLbl.Text = fmt(defV); vLbl.TextSize = 14; vLbl.Font = Enum.Font.GothamBold
    vLbl.TextColor3 = C.aHi; vLbl.TextXAlignment = Enum.TextXAlignment.Right
    vLbl.TextYAlignment = Enum.TextYAlignment.Center

    local track = Instance.new("Frame")
    track.Parent = card; track.BackgroundColor3 = C.card
    track.BorderSizePixel = 0
    track.Position = UDim2.new(0,0,0,24); track.Size = UDim2.new(1,0,0,6)
    rnd(track, 99)

    local fill = Instance.new("Frame")
    fill.Parent = track; fill.BackgroundColor3 = C.accent
    fill.BorderSizePixel = 0
    fill.Size = UDim2.new((defV-minV)/(maxV-minV),0,1,0)
    rnd(fill, 99)

    local knob = Instance.new("TextButton")
    knob.Parent = track; knob.BackgroundColor3 = C.white
    knob.BorderSizePixel = 0; knob.Text = ""; knob.AutoButtonColor = false
    knob.Size = UDim2.new(0,18,0,18)
    knob.Position = UDim2.new((defV-minV)/(maxV-minV),-9,0.5,-9)
    rnd(knob, 99)

    local cur = defV
    local isDrag = false

    local function apply(pct)
        pct = math.clamp(pct,0,1)
        cur = math.clamp(math.round((minV+pct*(maxV-minV))/step)*step, minV, maxV)
        local p = (cur-minV)/(maxV-minV)
        fill.Size = UDim2.new(p,0,1,0)
        knob.Position = UDim2.new(p,-9,0.5,-9)
        vLbl.Text = fmt(cur)
        onChange(cur)
    end
    local function pctOf(pos)
        return (pos.X-track.AbsolutePosition.X)/track.AbsoluteSize.X
    end

    knob.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=true end
    end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
            isDrag=true; apply(pctOf(i.Position))
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not isDrag then return end
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement then apply(pctOf(i.Position)) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=false end
    end)
end

