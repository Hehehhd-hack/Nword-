end

local function updateInfo()
    local n = #MS.inputs
    vInputs.Text   = tostring(n)
    vDuration.Text = n>0 and string.format("%.2fs", MS.inputs[n].time) or "0.00s"
end

-- Macro list rebuilder
local macroItems = {}  -- holds frames so we can destroy them

local function refreshMacroList()
    -- destroy old items
    for _, f in ipairs(macroItems) do f:Destroy() end
    macroItems = {}

    local itemY = macroListY
    local count = 0

    for name, data in pairs(MS.macros) do
        count = count + 1
        local itemH = RH.macroItem

        local row = Instance.new("Frame")
        row.Parent           = scroll
        row.BackgroundColor3 = CARD
        row.BorderSizePixel  = 0
        row.Position         = UDim2.new(0, 12, 0, itemY)
        row.Size             = UDim2.new(1, -24, 0, itemH - 4)
        do local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,8);c.Parent=row end

        table.insert(macroItems, row)

        local nl = Instance.new("TextLabel"); nl.Parent=row
        nl.BackgroundTransparency=1; nl.Position=UDim2.new(0,10,0,0); nl.Size=UDim2.new(1,-80,1,0)
        nl.Text=name; nl.TextSize=12; nl.Font=Enum.Font.GothamBold; nl.TextColor3=TEXT
        nl.TextXAlignment=Enum.TextXAlignment.Left; nl.TextYAlignment=Enum.TextYAlignment.Center

        local cl = Instance.new("TextLabel"); cl.Parent=row
        cl.BackgroundTransparency=1; cl.Position=UDim2.new(1,-80,0,0); cl.Size=UDim2.new(0,46,1,0)
        cl.Text=#data.inputs.." ev"; cl.TextSize=11; cl.Font=Enum.Font.Gotham; cl.TextColor3=SUB
        cl.TextXAlignment=Enum.TextXAlignment.Right; cl.TextYAlignment=Enum.TextYAlignment.Center

        local delB = Instance.new("TextButton"); delB.Parent=row
        delB.BackgroundColor3=Color3.fromRGB(55,18,18); delB.BorderSizePixel=0
        delB.Position=UDim2.new(1,-32,0.5,-14); delB.Size=UDim2.new(0,28,0,28)
        delB.Text="✕"; delB.Font=Enum.Font.GothamBold; delB.TextColor3=RED
        delB.TextSize=13; delB.AutoButtonColor=false
        do local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,6);c.Parent=delB end

        -- Tap row = load
        row.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
                nameBox.Text = name
                MS.inputs = data.inputs
                updateInfo()
                setStatus("Loaded: "..name, ACC)
            end
        end)
        delB.MouseButton1Click:Connect(function()
            MS.macros[name] = nil
            refreshMacroList()
        end)

        itemY = itemY + itemH
    end

    if count == 0 then
        local el = Instance.new("TextLabel"); el.Parent=scroll
        el.BackgroundTransparency=1
        el.Position=UDim2.new(0,0,0,itemY); el.Size=UDim2.new(1,0,0,RH.emptyLabel)
        el.Text="No saved macros"; el.TextSize=12; el.Font=Enum.Font.Gotham
        el.TextColor3=MUTED; el.TextXAlignment=Enum.TextXAlignment.Center
        el.TextYAlignment=Enum.TextYAlignment.Center
        table.insert(macroItems, el)
        itemY = itemY + RH.emptyLabel
    end

    -- Grow canvas if needed
    local needed = itemY + RH.spacer * 3
    if needed > CANVAS_H then
        scroll.CanvasSize = UDim2.new(0, 0, 0, needed)
    end
end

function MS:StartRec()
    if self.playing then return end
    self.recording=true; self.inputs={}; self.recStart=tick()
    setStatus("Recording…", RED)
    recBtn:RC(Color3.fromRGB(140,30,30)); recBtn.Text="⏹  Stop Rec"
    updateInfo()
end

function MS:StopRec()
    if not self.recording then return end
    self.recording=false; updateInfo()
    setStatus("Recorded "..#self.inputs.." inputs", YELLOW)
    recBtn:RC(RED); recBtn.Text="⏺  Record"
    setProgress(0)
end

function MS:StopPlay()
    self.stopReq=true; self.playing=false
    setStatus("Stopped", MUTED)
    playBtn:RC(GREEN); playBtn.Text="▶  Play"
    loopLbl.Text=""; setProgress(0)
end

function MS:PlayOnce(inputs, totalDur)
    local base = tick()
    for _, ev in ipairs(inputs) do
        if self.stopReq then return false end
        local target = base + (ev.time / CFG.speedMult)
        local now = tick()
        if target > now then task.wait(target - now) end
        if self.stopReq then return false end
        if VIM then
            pcall(function()
                if ev.t=="TD" or ev.t=="MD" then
                    VIM:SendMouseButtonEvent(ev.x, ev.y, 0, true,  game, 0)
                elseif ev.t=="TU" or ev.t=="MU" then
                    VIM:SendMouseButtonEvent(ev.x, ev.y, 0, false, game, 0)
                elseif ev.t=="TM" or ev.t=="MM" then
                    VIM:SendMouseMoveEvent(ev.x, ev.y, game)
                end
            end)
        end
        if totalDur > 0 then setProgress(ev.time / totalDur) end
    end
    return true
end

function MS:Play()
    if self.recording then self:StopRec() end
    if self.playing   then self:StopPlay(); return end
    if #self.inputs == 0 then setStatus("Nothing to play!", RED); return end

    self.playing=true; self.stopReq=false
    playBtn:RC(YELLOW); playBtn.Text="⏸  Stop"

    local inputs   = self.inputs
    local totalDur = inputs[#inputs] and inputs[#inputs].time or 0

    task.spawn(function()
        if CFG.startDelay > 0 then
            setStatus(string.format("Starting in %.1fs…", CFG.startDelay), YELLOW)
            task.wait(CFG.startDelay)
            if self.stopReq then self:StopPlay(); return end
        end

        local maxL = CFG.loopCount==0 and math.huge or CFG.loopCount
        local loop = 0

        while loop < maxL and not self.stopReq do
            loop = loop + 1
            loopLbl.Text = CFG.loopCount==0
                and string.format("Loop %d / ∞", loop)
                or  string.format("Loop %d / %d", loop, CFG.loopCount)
            setStatus("Playing…", GREEN)

            local ok = self:PlayOnce(inputs, totalDur)
            if not ok or self.stopReq then break end
            setProgress(1)

            if loop < maxL and CFG.loopDelay > 0 and not self.stopReq then
                setStatus(string.format("Loop pause %.1fs…", CFG.loopDelay), YELLOW)
                task.wait(CFG.loopDelay)
            end
        end

        if not self.stopReq then
            self:StopPlay()
            setStatus(string.format("Done (%d loop%s)", loop, loop==1 and "" or "s"), GREEN)
        end
    end)
end

