-- ════════════════════════════════════════
--  INPUT RECORDING
--  FIX 2: Use InputBegan on UIS directly.
--  On mobile executors, TouchStarted may
--  fire with processed=true and get swallowed.
--  UIS.InputBegan fires regardless.
-- ════════════════════════════════════════
local activeTouches = {}  -- track active touch IDs for move events

local function isInsideWin(x, y)
    local ap=win.AbsolutePosition; local as=win.AbsoluteSize
    return x>=ap.X and x<=ap.X+as.X and y>=ap.Y and y<=ap.Y+as.Y
end

local function recEvent(t2, x, y)
    if not MS.recording then return end
    if isInsideWin(x, y) then return end
    local t=tick()-MS.recStart
    table.insert(MS.inputs,{t=t2,x=x,y=y,time=t})
    updateInfo()
end

-- PRIMARY: InputBegan / InputChanged / InputEnded (works on mobile)
UIS.InputBegan:Connect(function(inp, processed)
    -- Record touch regardless of processed flag
    if inp.UserInputType == Enum.UserInputType.Touch then
        activeTouches[inp] = true
        recEvent("TD", inp.Position.X, inp.Position.Y)
    elseif inp.UserInputType == Enum.UserInputType.MouseButton1 and CFG.recMouse and not processed then
        recEvent("MD", inp.Position.X, inp.Position.Y)
    end
end)

UIS.InputChanged:Connect(function(inp, processed)
    if inp.UserInputType == Enum.UserInputType.Touch and activeTouches[inp] then
        recEvent("TM", inp.Position.X, inp.Position.Y)
    elseif inp.UserInputType == Enum.UserInputType.MouseMovement and CFG.recMouse and not processed then
        recEvent("MM", inp.Position.X, inp.Position.Y)
    end
end)

UIS.InputEnded:Connect(function(inp, processed)
    if inp.UserInputType == Enum.UserInputType.Touch then
        activeTouches[inp] = nil
        recEvent("TU", inp.Position.X, inp.Position.Y)
    elseif inp.UserInputType == Enum.UserInputType.MouseButton1 and CFG.recMouse and not processed then
        recEvent("MU", inp.Position.X, inp.Position.Y)
    end
end)

