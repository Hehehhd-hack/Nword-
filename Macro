local curTab = 1
local function switchTab(idx)
    curTab = idx
    for i, tb in ipairs(tabBtns) do
        local on = (i == idx)
        tw(tb, {BackgroundColor3 = on and ACC or CARD, TextColor3 = on and WHITE or SUB}, .15)
        tabPages[i].Visible = on
    end
end
for i, tb in ipairs(tabBtns) do
    tb.MouseButton1Click:Connect(function() switchTab(i) end)
end

-- ════════════════════════════════════════
--  PAGE BUILDER HELPER
--  Builds into a given ScrollingFrame page
--  Returns canvas height used
-- ════════════════════════════════════════
local function buildPage(sf, buildFn)
    local y = 0
    local items = {}

    local function place(h, bg)
        local f = Instance.new("Frame")
        f.Parent          = sf
        f.BackgroundColor3 = bg or BG
        f.BorderSizePixel = 0
        f.Position        = UDim2.new(0, 0, 0, y)
        f.Size            = UDim2.new(1, 0, 0, h)
        table.insert(items, f)
        y = y + h
        return f
    end

    local function spacer(h) place(h or 8, BG) end
    local function divider() place(1, BORDER) end

    local function hdr(title)
        local f = place(26, BG)
        local l = Instance.new("TextLabel")
        l.Parent=f; l.BackgroundTransparency=1
        l.Position=UDim2.new(0,12,0,0); l.Size=UDim2.new(1,-24,1,0)
        l.Text=title; l.TextSize=10; l.Font=Enum.Font.GothamBold
        l.TextColor3=MUTED; l.TextXAlignment=Enum.TextXAlignment.Left
        l.TextYAlignment=Enum.TextYAlignment.Center
    end

    local results = buildFn(place, spacer, divider, hdr, y)
    sf.CanvasSize = UDim2.new(0, 0, 0, y + 20)
    return results
end

