-- ════════════════════════════════════════
local function rec(t2, x, y)
    if not MS.recording then return end
    local ap = win.AbsolutePosition; local as = win.AbsoluteSize
    if x >= ap.X and x <= ap.X+as.X and y >= ap.Y and y <= ap.Y+as.Y then return end
    local t = tick() - MS.recStart
    table.insert(MS.inputs, {t=t2, x=x, y=y, time=t})
    updateInfo()
end

UIS.TouchStarted:Connect(function(touch,_) rec("TD", touch.Position.X, touch.Position.Y) end)
UIS.TouchMoved:Connect(  function(touch,_) rec("TM", touch.Position.X, touch.Position.Y) end)
UIS.TouchEnded:Connect(  function(touch,_) rec("TU", touch.Position.X, touch.Position.Y) end)

UIS.InputBegan:Connect(function(i,_)
    if i.UserInputType==Enum.UserInputType.MouseButton1 and CFG.recMouse then
        rec("MD", i.Position.X, i.Position.Y)
    end
end)
UIS.InputChanged:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseMovement and CFG.recMouse and MS.recording then
        rec("MM", i.Position.X, i.Position.Y)
    end
end)
UIS.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 and CFG.recMouse then
        rec("MU", i.Position.X, i.Position.Y)
    end
end)

