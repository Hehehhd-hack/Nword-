--  PANEL SHOW / HIDE
-- ══════════════════════════════════════════════
local panelOpen = true

local function openPanel()
    panelOpen = true
    fab.Visible = false
    tween(mainFrame, {Position = SHEET_Y_OPEN}, 0.35, Enum.EasingStyle.Quint)
end

local function closePanel()
    panelOpen = false
    tween(mainFrame, {Position = SHEET_Y_CLOSED}, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    task.delay(0.3, function() fab.Visible = true end)
end

-- Swipe down on pill to close
local pillDragY = nil
pill.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        pillDragY = inp.Position.Y
    end
end)
pill.InputEnded:Connect(function(inp)
    if pillDragY then
        if inp.Position.Y - pillDragY > 35 then closePanel() end
        pillDragY = nil
    end
end)

fab.MouseButton1Click:Connect(openPanel)

-- Also allow clicking pill area to close if already open
pill.MouseButton1Click:Connect(function()
    if panelOpen then closePanel() else openPanel() end
end)

-- ══════════════════════════════════════════════
--  MACRO CORE LOGIC
-- ══════════════════════════════════════════════

function MacroSystem:StartRecording()
    if self.isPlaying then return end
    self.isRecording        = true
    self.recordedInputs     = {}
    self.recordingStartTime = tick()
    updateStatus("Recording…", C.red)
    recordBtn:SetColor(Color3.fromRGB(140, 30, 30))
    recordBtn.Text = "⏹  Stop Rec"
    inputCountVal.Text = "0"
    durationVal.Text   = "0.00s"
end

function MacroSystem:StopRecording()
    if not self.isRecording then return end
    self.isRecording = false
    local dur = self.recordedInputs[#self.recordedInputs] and self.recordedInputs[#self.recordedInputs].time or 0
    updateStatus("Recorded " .. #self.recordedInputs .. " inputs", C.yellow)
    recordBtn:SetColor(C.red)
    recordBtn.Text = "⏺  Record"
    inputCountVal.Text = tostring(#self.recordedInputs)
    durationVal.Text   = string.format("%.2fs", dur)
    setProgress(0)
end

function MacroSystem:StopPlayback()
    self.stopRequested = true
    self.isPlaying     = false
    updateStatus("Stopped", C.muted)
    playBtn.Text = "▶  Play"
    playBtn:SetColor(C.green)
    loopInfoLabel.Text = ""
    setProgress(0)
end

function MacroSystem:PlayOnce(inputs, totalDuration)
    local startT = tick()
    for i, inp in ipairs(inputs) do
        if self.stopRequested then return false end
        local targetT = startT + (inp.time / Settings.speedMult)
        local now = tick()
        if targetT > now then task.wait(targetT - now) end
        if self.stopRequested then return false end

        -- Simulate input
        if inp.type == "TouchStart" or inp.type == "MouseDown" then
            -- Fire a VirtualInputManager tap if available
            if VirtualInputManager then
                pcall(function()
                    VirtualInputManager:SendMouseButtonEvent(inp.position.X, inp.position.Y, 0, true, game, 0)
                end)
            end
        elseif inp.type == "TouchEnd" or inp.type == "MouseUp" then
            if VirtualInputManager then
                pcall(function()
                    VirtualInputManager:SendMouseButtonEvent(inp.position.X, inp.position.Y, 0, false, game, 0)
                end)
            end
        elseif inp.type == "TouchMoved" or inp.type == "MouseMoved" then
            if VirtualInputManager then
                pcall(function()
                    VirtualInputManager:SendMouseMoveEvent(inp.position.X, inp.position.Y, game)
                end)
            end
        end

        -- Update progress
        if totalDuration > 0 then
            setProgress(inp.time / totalDuration)
        end
    end
    return true
end

function MacroSystem:Play()
    if self.isRecording then self:StopRecording() end
    if self.isPlaying   then self:StopPlayback(); return end
    if #self.recordedInputs == 0 then
        updateStatus("Nothing to play!", C.red)
        return
    end

    self.isPlaying     = true
    self.stopRequested = false
    playBtn.Text = "⏸  Stop"
    playBtn:SetColor(C.yellow)

    local inputs = self.recordedInputs
    local totalDuration = inputs[#inputs] and inputs[#inputs].time or 0

    task.spawn(function()
        -- Start delay
        if Settings.startDelay > 0 then
            updateStatus(string.format("Starting in %.1fs…", Settings.startDelay), C.yellow)
            task.wait(Settings.startDelay)
            if self.stopRequested then
                self:StopPlayback(); return
            end
        end

        local maxLoops = Settings.loopCount == 0 and math.huge or Settings.loopCount
        local loop = 0

        while loop < maxLoops and not self.stopRequested do
            loop = loop + 1
            self.currentLoopsDone = loop

            if Settings.loopCount == 0 then
                loopInfoLabel.Text = string.format("Loop %d / ∞", loop)
            else
                loopInfoLabel.Text = string.format("Loop %d / %d", loop, Settings.loopCount)
            end
            updateStatus("Playing…", C.green)

            local ok = self:PlayOnce(inputs, totalDuration)
            if not ok or self.stopRequested then break end

            setProgress(1)

            if loop < maxLoops and Settings.loopDelay > 0 and not self.stopRequested then
                updateStatus(string.format("Loop delay %.1fs…", Settings.loopDelay), C.yellow)
                task.wait(Settings.loopDelay)
            end
        end

        if not self.stopRequested then
            self:StopPlayback()
            updateStatus("Done  (" .. loop .. " loop" .. (loop == 1 and "" or "s") .. ")", C.green)
        end
    end)
end

-- ══════════════════════════════════════════════
--  REFRESH MACRO LIST
-- ══════════════════════════════════════════════
function MacroSystem:RefreshList()
    for _, c in ipairs(macroScrollFrame:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end

    local idx = 0
    for name, data in pairs(self.macros) do
        idx = idx + 1
        local row = Instance.new("Frame")
        row.Parent           = macroScrollFrame
        row.BackgroundColor3 = C.card
        row.BorderSizePixel  = 0
        row.Size             = UDim2.new(1, 0, 0, 46)
        row.LayoutOrder      = idx
        corner(row, 8)

        local rl = Instance.new("UIListLayout")
        rl.Parent            = row
        rl.FillDirection     = Enum.FillDirection.Horizontal
        rl.VerticalAlignment = Enum.VerticalAlignment.Center
        pad(row, 0, 0, 12, 8)

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Parent               = row
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text                 = name
        nameLbl.Font                 = Enum.Font.GothamBold
        nameLbl.TextSize             = 13
        nameLbl.TextColor3           = C.text
        nameLbl.TextXAlignment       = Enum.TextXAlignment.Left
        nameLbl.Size                 = UDim2.new(1, -90, 1, 0)

        local subLbl = Instance.new("TextLabel")
        subLbl.Parent               = row
        subLbl.BackgroundTransparency = 1
        subLbl.Text                 = tostring(#data.inputs) .. " inputs"
        subLbl.Font                 = Enum.Font.Gotham
        subLbl.TextSize             = 11
        subLbl.TextColor3           = C.subtext
        subLbl.TextXAlignment       = Enum.TextXAlignment.Right
        subLbl.Size                 = UDim2.new(0, 70, 1, 0)

        local delBtn = Instance.new("TextButton")
        delBtn.Parent           = row
        delBtn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
        delBtn.BorderSizePixel  = 0
        delBtn.Text             = "✕"
        delBtn.Font             = Enum.Font.GothamBold
        delBtn.TextColor3       = C.red
        delBtn.TextSize         = 14
        delBtn.Size             = UDim2.new(0, 28, 0, 28)
        delBtn.AutoButtonColor  = false
        corner(delBtn, 6)

        -- Tap row to select
        local rowBtn = Instance.new("TextButton")
        rowBtn.Parent             = row
        rowBtn.BackgroundTransparency = 1
        rowBtn.Size               = UDim2.new(0, 0, 0, 0) -- invisible; we use the row itself
        rowBtn.Text               = ""

        row.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                nameBox.Text = name
                MacroSystem:LoadMacro(name)
            end
        end)

        delBtn.MouseButton1Click:Connect(function()
            self.macros[name] = nil
            self:RefreshList()
        end)
    end

    if idx == 0 then
        local empty = label(macroScrollFrame, "No saved macros", 13, C.muted, Enum.Font.Gotham, Enum.TextXAlignment.Center)
        empty.Size = UDim2.new(1, 0, 0, 40)
    end
end

function MacroSystem:SaveMacro(name)
    if name == "" then updateStatus("Enter a name first!", C.red); return end
    self.macros[name] = {inputs = self.recordedInputs}
    updateStatus("Saved: " .. name, C.accent)
    self:RefreshList()
end

function MacroSystem:LoadMacro(name)
    if not self.macros[name] then updateStatus("Not found!", C.red); return end
    self.recordedInputs = self.macros[name].inputs
    local dur = self.recordedInputs[#self.recordedInputs] and self.recordedInputs[#self.recordedInputs].time or 0
    inputCountVal.Text = tostring(#self.recordedInputs)
    durationVal.Text   = string.format("%.2fs", dur)
    updateStatus("Loaded: " .. name, Color3.fromRGB(160, 100, 255))
    switchTab(1)
end

-- ══════════════════════════════════════════════
--  INPUT RECORDING
-- ══════════════════════════════════════════════
local function recordInput(inputType, pos)
    if not MacroSystem.isRecording then return end
    local t = tick() - MacroSystem.recordingStartTime
    table.insert(MacroSystem.recordedInputs, {
        type     = inputType,
        position = pos,
        time     = t,
    })
    inputCountVal.Text = tostring(#MacroSystem.recordedInputs)
    durationVal.Text   = string.format("%.2fs", t)
end

-- Touch events
UIS.TouchStarted:Connect(function(touch, processed)
    recordInput("TouchStart", touch.Position)
end)
UIS.TouchMoved:Connect(function(touch, processed)
    recordInput("TouchMoved", touch.Position)
end)
UIS.TouchEnded:Connect(function(touch, processed)
    recordInput("TouchEnd", touch.Position)
end)

-- Mouse events (PC fallback / dual support)
UIS.InputBegan:Connect(function(inp, processed)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 and Settings.recordMouse then
        recordInput("MouseDown", inp.Position)
    end
end)
UIS.InputChanged:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseMovement and Settings.recordMouse and MacroSystem.isRecording then
        recordInput("MouseMoved", inp.Position)
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 and Settings.recordMouse then
        recordInput("MouseUp", inp.Position)
    end
end)

