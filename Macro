-- Helper: slider row
local function sliderRow(page, title, minVal, maxVal, defaultVal, step, fmt, onChange, order)
    local sec = section(page, title, order)

    local valLabel = label(sec, fmt(defaultVal), 20, C.accentHi, Enum.Font.GothamBold, Enum.TextXAlignment.Right)
    valLabel.Size = UDim2.new(1, 0, 0, 26)
    valLabel.LayoutOrder = 1

    local track = Instance.new("Frame")
    track.Parent           = sec
    track.BackgroundColor3 = C.card
    track.BorderSizePixel  = 0
    track.Size             = UDim2.new(1, 0, 0, 8)
    track.LayoutOrder      = 2
    corner(track, 99)

    local fill = Instance.new("Frame")
    fill.Parent           = track
    fill.BackgroundColor3 = C.accent
    fill.BorderSizePixel  = 0
    fill.Size             = UDim2.new((defaultVal - minVal)/(maxVal - minVal), 0, 1, 0)
    corner(fill, 99)

    local knob = Instance.new("TextButton")
    knob.Parent           = track
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel  = 0
    knob.Text             = ""
    knob.AutoButtonColor  = false
    knob.Size             = UDim2.new(0, 22, 0, 22)
    knob.Position         = UDim2.new((defaultVal - minVal)/(maxVal - minVal), -11, 0.5, -11)
    corner(knob, 99)

    local current = defaultVal
    local dragging = false

    local function setValue(pct)
        pct = math.clamp(pct, 0, 1)
        local raw = minVal + pct * (maxVal - minVal)
        current = math.round(raw / step) * step
        current = math.clamp(current, minVal, maxVal)
        local p = (current - minVal)/(maxVal - minVal)
        fill.Size     = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, -11, 0.5, -11)
        valLabel.Text = fmt(current)
        onChange(current)
    end

    local function getPct(inputPos)
        local abs = track.AbsolutePosition
        local sz  = track.AbsoluteSize
        return (inputPos.X - abs.X) / sz.X
    end

    knob.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseMovement then
            setValue(getPct(inp.Position))
        end
    end)

    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            setValue(getPct(inp.Position))
            dragging = true
        end
    end)

    return sec
end

