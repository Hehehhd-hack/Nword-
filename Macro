-- Button row helper (2 buttons)
local function makeBtnRow(def1, def2)
    local f = place(RH.btnRow, BG)
    local pad = 12
    local bw  = math.floor((WIN_W - pad*2 - 8) / 2)
    local bh  = 40

    local function mkb(def, xPos)
        local b = Instance.new("TextButton")
        b.Parent=f; b.BackgroundColor3=def.bg; b.BorderSizePixel=0
        b.Position=UDim2.new(0,xPos,0,5); b.Size=UDim2.new(0,bw,0,bh)
        b.Text=def.txt; b.Font=Enum.Font.GothamBold; b.TextSize=13
        b.TextColor3=def.fg or WHITE; b.AutoButtonColor=false
        local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,9);c.Parent=b
        local orig=def.bg
        b.MouseButton1Down:Connect(function() tw(b,{BackgroundColor3=orig:Lerp(WHITE,.22)},.06) end)
        b.MouseButton1Up:Connect(function()   tw(b,{BackgroundColor3=orig},.12) end)
        function b:RC(col) orig=col; b.BackgroundColor3=col end
        return b
    end

    local b1 = mkb(def1, pad)
    local b2 = mkb(def2, pad + bw + 8)
    return b1, b2
end

