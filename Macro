local function switchTab(idx)
    currentTab = idx
    for i, btn in ipairs(tabButtons) do
        local active = (i == idx)
        tween(btn, {
            BackgroundColor3 = active and C.accent or C.card,
            TextColor3       = active and C.text   or C.subtext,
        }, 0.15)
        tabPages[i].Visible = active
    end
